<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <style>
            @page {
                size: 5cm 2.5cm;
                margin: 0;
            }

            body {
                margin: 0;
                padding: 0;
                font-size: 10px;
                font-family: sans-serif;
            }

            .label-page {
                width: 5cm;
                height: 2.4cm;
                page-break-after: always;
            }

            .container {
                width: 100%;
                height: 100%;
                background-color: white;
                box-sizing: border-box;
                overflow: hidden;
                padding: 1px;
            }

            .row {
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .qr {
                height: 85%;
                width: 40%;
            }
            .logo {
                margin-left: 30px;
                width: 40%;
                height: calc(80% - 4px);
            }

            .asset-id {
                margin-top: -2px;
                text-align: center;
            }
        </style>
    </head>
    <body>
        <% for (let label of labels) { %>
        <div class="label-page">
            <div class="container">
                <div class="row" style="display: flexbox">
                    <img class="qr" src="<%= label.qr %>" alt="QR Code" />
                    <img
                        class="logo"
                        src="data:image/png;base64,"
                        alt="Logo"
                    />
                </div>
                <p class="asset-id"><%= label.assetId %></p>
            </div>
        </div>
        <% } %>
    </body>
</html>
